{
  "name": "AgriDistro — Agricultural Intervention System",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },

  "forwardPorts": [8001, 5173],
  "portsAttributes": {
    "8001": { "label": "Backend API", "onAutoForward": "silent" },
    "5173": { "label": "Frontend App", "onAutoForward": "openBrowserOnce" }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/start.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      }
    }
  }
}
